# WeatherCast Studio — 실제 API 연동 시 사용할 환경변수 (현재 MVP는 전부 목업이라 불필요)
# 아래 키들을 채우고 app/api/*/route.ts 의 목업 로직을 실제 호출로 교체하세요.

# 케이웨더 (KWeather) — gateway.kweather.co.kr:8443 (Wellbian API 레이어 기준)
# 가입/키발급: api.kweather.co.kr (비상업용 1일 5,000콜 무료 / 상업용·방송용은 유료 계약)
# KWEATHER_API_KEY 만 설정하면 /api/weather가 케이웨더 시간별예보(kw-3d1h2)를 우선 사용
# (호출 실패/미설정 시 Open-Meteo 실데이터로 자동 폴백)
KWEATHER_API_KEY=
# 기본 게이트웨이 URL (보통 변경 불필요)
# KWEATHER_BASE_URL=https://gateway.kweather.co.kr:8443/weather/w3/v2/kw-sensors

# Google Gemini (가사·프롬프트 실연동) — 키발급: https://aistudio.google.com/apikey (무료 티어 있음)
# GEMINI_API_KEY 설정 시 /api/lyrics 가 Gemini로 가사 생성(실패/미설정 시 목업 폴백)
GEMINI_API_KEY=
# 모델 (선택, 기본 gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Suno (음원 생성) — 공식/승인 API 또는 제휴 엔드포인트
SUNO_API_KEY=
SUNO_BASE_URL=

# 영상 생성 (OmniHuman / Seedance) — ByteDance Volcengine 등
VIDEO_API_KEY=
VIDEO_BASE_URL=

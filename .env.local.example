# WeatherCast Studio — 실제 API 연동 시 사용할 환경변수 (현재 MVP는 전부 목업이라 불필요)
# 아래 키들을 채우고 app/api/*/route.ts 의 목업 로직을 실제 호출로 교체하세요.

# 케이웨더 (KWeather) B2B API
KWEATHER_API_KEY=
KWEATHER_BASE_URL=

# Google Gemini (가사/프롬프트 생성)
GEMINI_API_KEY=

# Suno (음원 생성) — 공식/승인 API 또는 제휴 엔드포인트
SUNO_API_KEY=
SUNO_BASE_URL=

# 영상 생성 (OmniHuman / Seedance) — ByteDance Volcengine 등
VIDEO_API_KEY=
VIDEO_BASE_URL=
